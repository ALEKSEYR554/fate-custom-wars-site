<style>
  body { background: #121212; color: #fff; font-family: sans-serif; padding: 20px; }
  .admin-table { width: 100%; border-collapse: collapse; background: #1e1e1e; }
  .admin-table th, .admin-table td { padding: 10px; border: 1px solid #333; text-align: left; }
  .btn { background: #90caf9; color: #000; padding: 5px 10px; text-decoration: none; border-radius: 3px; font-size: 0.9em; }
  .nav-bar { background: #1e1e1e; padding: 15px; margin-bottom: 20px; border: 1px solid #333; border-radius: 4px; }
  .nav-bar a { color: #90caf9; text-decoration: none; margin-right: 15px; font-weight: bold; }
</style>

<div class="nav-bar" style="display: flex; justify-content: space-between; align-items: center;">
  <div>
    <a href="<%= admin_servants_path %>">Слуги</a>
    <a href="<%= admin_craft_essences_path %>" style="color: #fff;">Карты (CE)</a>
  </div>

  <%= button_to "💾 Бэкап в Telegram", backup_telegram_admin_servants_path, method: :post, form: {style: "margin:0;"}, style: "background: #cf6679; color: #000; border: none; padding: 5px 10px; border-radius: 3px; font-weight: bold; cursor: pointer;" %>

</div>

<h1>Админ-панель: Карты (Craft Essences)</h1>
<% if flash[:notice] %>
  <div style="background: #03dac6; color: #000; padding: 10px; margin-bottom: 20px;"><%= flash[:notice] %></div>
<% end %>

<table class="admin-table">
  <tr>
    <th>ID</th>
    <th>Название</th>
    <th>Действия</th>
  </tr>
  <% @ces.each do |ce| %>
    <tr>
      <td><%= ce.game_id %></td>
      <td><%= ce.name %></td>
      <td>
        <a href="<%= edit_admin_craft_essence_path(ce.game_id) %>" class="btn">✏️ Редактировать</a>
      </td>
    </tr>
  <% end %>
</table>