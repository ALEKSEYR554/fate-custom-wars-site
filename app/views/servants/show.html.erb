<style>
  :root {
    --bg-base: #121212;
    --bg-surface: #1e1e1e;
    --bg-elevated: #2d2d2d;
    --text-primary: rgba(255, 255, 255, 0.87);
    --text-secondary: rgba(255, 255, 255, 0.60);
    --border-color: #424242;
    --atlas-blue: #90caf9;
    --font-stack: 'Roboto', 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  }

  body {
    background-color: var(--bg-base);
    color: var(--text-primary);
    font-family: var(--font-stack);
    padding: 20px;
    line-height: 1.5;
  }

  .container {
    max-width: 800px;
    margin: 0 auto;
    background: var(--bg-surface);
    border: 1px solid var(--border-color);
    border-radius: 4px;
    padding: 24px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
  }

  h1 {
    color: var(--atlas-blue);
    font-size: 2rem;
    font-weight: 500;
    margin-top: 0;
    margin-bottom: 20px;
    border-bottom: 1px solid var(--border-color);
    padding-bottom: 10px;
  }

  .section {
    margin-bottom: 24px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--border-color);
  }

  .section h2 {
    color: var(--text-primary);
    font-size: 1.25rem;
    font-weight: 500;
    margin-top: 0;
    margin-bottom: 15px;
  }

  .preview-image {
    width: 100%;
    max-height: 400px;
    object-fit: contain;
    background: #000;
    border: 1px solid var(--border-color);
    border-radius: 4px;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 12px;
  }

  .stat-box {
    background: var(--bg-elevated);
    border: 1px solid var(--border-color);
    padding: 12px;
    border-radius: 4px;
    font-size: 0.9rem;
  }

  .stat-box strong {
    color: var(--atlas-blue);
  }
</style>


<div class="container">
  <%
    # Формируем чистый текст для копирования
    copy_lines = []
    copy_lines << @servant.game_id
    copy_lines << "Мировоззрение: #{@servant.alignment}" if @servant.alignment.present?
    copy_lines << "Класс: #{@servant.servant_class}" if @servant.servant_class.present?
    copy_lines << "Имя: #{@servant.name}" if @servant.name.present?
    
    str = "Сила: #{@servant.strength_rank}"
    str += " (#{@servant.damage} урона)" if @servant.damage.present?
    copy_lines << str if @servant.strength_rank.present?

    endur = "Выносливость: #{@servant.endurance_rank}"
    endur += " (Очки Жизни: #{@servant.hp})" if @servant.hp.present?
    copy_lines << endur if @servant.endurance_rank.present?

    agi = "Ловкость: #{@servant.agility_rank}"
    agi += " (+#{@servant.agility_modifier})" if @servant.agility_modifier.present?
    copy_lines << agi if @servant.agility_rank.present?

    luck = "Удача: #{@servant.luck_rank}"
    luck += " (+#{@servant.luck_modifier})" if @servant.luck_modifier.present?
    copy_lines << luck if @servant.luck_rank.present?

    mag = "Магия: #{@servant.magic_rank}"
    if @servant.magic_defense.present? || @servant.magic_damage.present?
      m_parts = []
      m_parts << "Магическая Защита - #{@servant.magic_defense}" if @servant.magic_defense.present?
      m_parts << "Урон - #{@servant.magic_damage}" if @servant.magic_damage.present?
      mag += " (#{m_parts.join(' / ')})"
    end
    copy_lines << mag if @servant.magic_rank.present?

    copy_lines << "Н.Фантазм: #{@servant.np_rank}" if @servant.np_rank.present?
    copy_lines << "Классовые Навыки:\n#{@servant.class_skills.strip}" if @servant.class_skills.present?
    copy_lines << "Личные Навыки:\n#{@servant.personal_skills.strip}" if @servant.personal_skills.present?
    copy_lines << "Небесный Фантазм:\n#{@servant.noble_phantasm.strip}" if @servant.noble_phantasm.present?
  %>

  <!-- Скрытое поле для хранения текста -->
  <textarea id="raw-servant-data" style="display: none;"><%= copy_lines.join("\n") %></textarea>

  <!-- Заголовок с кнопкой -->
  <div style="display: flex; align-items: center; gap: 15px; margin-bottom: 20px; border-bottom: 1px solid var(--border-color); padding-bottom: 10px;">
    <h1 style="margin: 0; border: none; padding: 0;"><%= @servant.game_id %> - <%= @servant.name %></h1>
    
    <button id="copy-btn" style="background: var(--atlas-blue); color: #000; border: none; padding: 6px 12px; border-radius: 4px; cursor: pointer; font-weight: 500; font-size: 0.9rem; transition: 0.2s;">
      📋 Копировать
    </button>
  </div>

  <script>
    document.getElementById('copy-btn').addEventListener('click', function() {
      const text = document.getElementById('raw-servant-data').value;
      
      navigator.clipboard.writeText(text).then(() => {
        const btn = document.getElementById('copy-btn');
        btn.innerText = "✅ Скопировано!";
        btn.style.background = "#03dac6"; // Зеленый цвет успеха
        
        setTimeout(() => {
          btn.innerText = "📋 Копировать";
          btn.style.background = "var(--atlas-blue)";
        }, 2000);
      }).catch(err => {
        alert("Ошибка копирования: " + err);
      });
    });
  </script>
  <%# Читаем шаблон построчно %>
  <% @servant.layout_to_use.each_line do |line| %>
    
    <% tag = line.strip %>
    
    <%# ПАРСЕР ШОРТКОДОВ %>
    <%# ОБРАТИ ВНИМАНИЕ: case и первый when теперь внутри одного тега, чтобы между ними не было HTML-пробелов %>
    <% case tag 
       when '[preview_image]' %>
      
      <% if @servant.game_id.present? %>
        <div class="section">
          <img src="<%=Rails.configuration.x.protocol%>//servant-data.<%= Rails.configuration.x.base_domain %>/sprite/<%= @servant.game_id %>/preview.png" class="preview-image" alt="<%= @servant.name %>">
          <a href="https://apps.atlasacademy.io/db/JP/servant/<%= @servant.atlas_id %>/traits">Проверить Трейты</a>
        </div>
      <% end %>

    <% when '[Базовые характеристики]' %>
      <div class="section">
        <h2>Базовые характеристики</h2>
        <div class="stats-grid">
          <% if @servant.region.present? %>
            <div class="section">
              <div class="stat-box"><%= @servant.region %></div>
            </div>
          <% end %>
          <div class="stat-box"><strong>Класс:</strong> <%= @servant.servant_class %></div>
          <div class="stat-box"><strong>Имя:</strong> <%= @servant.name %></div>
          <div class="stat-box"><strong>Сила:</strong> <%= @servant.strength_rank %> (<%= @servant.damage %> очка урона)</div>
          <div class="stat-box"><strong>Выносливость:</strong> <%= @servant.endurance_rank %> (Очки Жизни: <%= @servant.hp %>)</div>
          <% if @servant.agility_modifier.present?%>
            <div class="stat-box"><strong>Ловкость:</strong> <%= @servant.agility_rank %> (+<%= @servant.agility_modifier %> к выпавшему результату при уклонении)</div>
            <%else%>
            <div class="stat-box"><strong>Ловкость:</strong> <%= @servant.agility_rank %></div>
          <%end%>
          <% if @servant.luck_modifier.present?%>
            <div class="stat-box"><strong>Удача:</strong> <%= @servant.luck_rank %> (+<%= @servant.luck_modifier %> к выпавшему результату при мгновенной смерти)</div>
            <%else%>
            <div class="stat-box"><strong>Удача:</strong> <%= @servant.luck_rank %></div>
          <%end%>

          <% if @servant.magic_damage.present?%>
            <div class="stat-box"><strong>Магия:</strong> <%= @servant.magic_rank %> (Магическая Защита - <%= @servant.magic_defense %> Магический Урон - <%= @servant.magic_damage %>)</div>
            <%else%>
            <div class="stat-box"><strong>Магия:</strong> <%= @servant.magic_rank %> (Магическая Защита - <%= @servant.magic_defense %>)</div>
          <%end%>
          
        </div>
      </div>

    <% when '[Классовые навыки]' %>
      <% if @servant.class_skills.present? %>
        <div class="section">
          <h2>Классовые навыки</h2>
          <%= simple_format(@servant.class_skills) %>
        </div>
      <% end %>

    <% when '[Личные навыки]' %>
      <% if @servant.personal_skills.present? %>
        <div class="section">
          <h2>Личные навыки</h2>
          <%= simple_format(@servant.personal_skills) %>
        </div>
      <% end %>

    <% when '[Фантазмы]' %>
      <% if @servant.noble_phantasm.present? %>
        <div class="section">
          <h2>Небесный Фантазм (<%= @servant.np_rank %>)</h2>
          <%= simple_format(@servant.noble_phantasm) %>
        </div>
      <% end %>
    <% when /^\[Спрайт\s+(.+?)\]$/ %>
      <%# $1 — это строка со всеми спрайтами, например "sprite1.png sprite2.png". 
          .split автоматически разрезает строку по пробелам и возвращает массив %>
      <% sprites = $1.split %>
      
      <div class="section">
        <div style="display: flex; gap: 15px; flex-wrap: wrap; justify-content: center; padding: 15px; border-radius: 8px;">
          <% sprites.each do |sprite_file| %>
            <%# Формируем ссылку на твой поддомен servant-data, используя динамический домен %>
            <% sprite_url = "#{Rails.configuration.x.protocol}//servant-data.#{Rails.configuration.x.base_domain}/sprite/#{@servant.game_id}/#{sprite_file}.png" %>
            
            <img src="<%= sprite_url %>" alt="<%= sprite_file %>" style="max-height: 400px; max-width: 100%; object-fit: contain;">
          <% end %>
        </div>
      </div>

    <%# === ТЕГ ДЛЯ ПРОИЗВОЛЬНОГО ТЕКСТА === %>
    <% when /^\[Текст\s+(.+?)\]$/ %>
      <div class="section">
        <%# Красивое оформление текста с полоской сбоку, как цитата %>
        <p style="padding-left: 15px; padding: 10px 15px; border-radius: 0 8px 8px 0;">
          <%= $1 %>
        </p>
      </div>
    <%# Синтаксис: [галерея файл1.png : Подпись один ; файл2.png : Подпись два] %>
    <% when /^\[Галерея\s+(.+?)\]$/ %>
      <%# Разрезаем по точке с запятой (;), чтобы разделить разные картинки %>
      <% items = $1.split(';') %>
      
      <div class="section">
        <div style="display: flex; gap: 20px; flex-wrap: wrap; justify-content: center; padding: 20px; border-radius: 8px;">
          
          <% items.each do |item| %>
            <%# Разрезаем по двоеточию (:). Цифра 2 означает "резать только по первому двоеточию", на случай если в подписи тоже будет двоеточие %>
            <% file, caption = item.split(':', 2).map(&:strip) %>
            <% next if file.blank? %>
            
            <% sprite_url = "#{Rails.configuration.x.protocol}//servant-data.#{Rails.configuration.x.base_domain}/sprite/#{@servant.game_id}/#{file}.png" %>
            
            <figure style="margin: 0; text-align: center; max-width: 300px;">
              <img src="<%= sprite_url %>" alt="<%= file %>" style="max-height: 350px; max-width: 100%; object-fit: contain; border-radius: 4px;">
              
              <%# Если подпись есть, выводим её красивым курсивом %>
              <% if caption.present? %>
                <figcaption style="margin-top: 10px; font-size: 0.95em; font-style: italic; border-top: 1px solid #444; padding-top: 5px;">
                  <%= caption.gsub('\n', '<br>').html_safe %>
                </figcaption>
              <% end %>
            </figure>
          <% end %>

        </div>
      </div>
    <% when /^\[Другой Слуга:\s*(.+?)\]$/ %>
      <% linked_servant_id = $1 %>
      <% linked_servant = Servant.find_by(game_id: linked_servant_id) %>
      <% if linked_servant %>
        <div class="section" style="border: 2px dashed #bb86fc; padding: 15px;">
          <h2>Связанный слуга: <%= linked_servant.name %></h2>
          <p>Класс: <%= linked_servant.servant_class %></p>
          <a href="/servants/<%= linked_servant.game_id %>" style="color: #bb86fc;">Перейти к слуге</a>
        </div>
      <% end %>

    <% else %>
      <% if tag.present? && !tag.start_with?('[') %>
        <p><%= tag %></p>
      <% end %>
      
    <% end %><%# Конец case %>
    
  <% end %><%# Конец цикла each_line %>

</div>
<script>
    document.getElementById('copy-btn').addEventListener('click', function() {
      const text = document.getElementById('raw-servant-data').value;
      const btn = document.getElementById('copy-btn');

      // Функция изменения цвета кнопки
      function showSuccess() {
        btn.innerText = "✅ Скопировано!";
        btn.style.background = "#03dac6"; // Зеленый цвет
        setTimeout(() => {
          btn.innerText = "📋 Копировать";
          btn.style.background = "var(--atlas-blue)";
        }, 2000);
      }

      // Попытка 1: Современный метод (только для HTTPS)
      if (navigator.clipboard && window.isSecureContext) {
        navigator.clipboard.writeText(text)
          .then(showSuccess)
          .catch(err => alert("Ошибка: " + err));
      } 
      // Попытка 2: Резервный метод (для HTTP)
      else {
        const textArea = document.createElement("textarea");
        textArea.value = text;
        
        // Прячем элемент с экрана
        textArea.style.position = "fixed";
        textArea.style.left = "-9999px";
        document.body.appendChild(textArea);
        
        textArea.focus();
        textArea.select();

        try {
          document.execCommand('copy');
          showSuccess();
        } catch (err) {
          alert("Ошибка резервного копирования: " + err);
        }

        textArea.remove();
      }
    });
  </script>